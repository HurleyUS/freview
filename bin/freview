#!/usr/bin/env zsh
## Fallow review public module surface.

set -u

root="."
format="markdown"
quiet=0
explain=0
summary=0
ci=0
fail_on_issues=0

usage() {
  cat <<'HELP'
Usage: freview [--quiet] [--explain] [--summary] [--format FORMAT] [--root ROOT]

Runs the local review suite and writes REVIEW.md without printing it back through
bat. If any section fails, freview exits 1 and prints the report to stdout.

Forwarded shared flags:
  -r/--root, -f/--format/--output, -q/--quiet, --explain, --summary,
  --ci, --fail-on-issues
HELP
}

while (( $# > 0 )); do
  case "$1" in
    -r|--root)
      root="${2:-.}"
      shift 2
      ;;
    -f|--format|--output)
      format="${2:-markdown}"
      shift 2
      ;;
    --format=*|--output=*)
      format="${1#*=}"
      shift
      ;;
    -q|--quiet)
      quiet=1
      shift
      ;;
    --explain)
      explain=1
      shift
      ;;
    --summary)
      summary=1
      shift
      ;;
    --ci)
      ci=1
      quiet=1
      format="sarif"
      fail_on_issues=1
      shift
      ;;
    --fail-on-issues)
      fail_on_issues=1
      shift
      ;;
    -h|--help|--usage)
      usage
      exit 0
      ;;
    *)
      printf "freview: unknown argument: %s\n" "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

review_file="$root/REVIEW.md"
script_dir="${0:A:h}"
scribe_bin="$script_dir/scribe"

if [[ ! -x "$scribe_bin" ]]; then
  printf "freview: bundled scribe not found or not executable: %s\n" "$scribe_bin" >&2
  exit 1
fi

fallow_args=("--root" "$root" "--format" "$format")
scribe_args=("--root" "$root" "--format" "$format")
(( quiet )) && fallow_args+=("--quiet") && scribe_args+=("--quiet")
(( explain )) && fallow_args+=("--explain") && scribe_args+=("--explain")
(( summary )) && fallow_args+=("--summary") && scribe_args+=("--summary")
(( ci )) && fallow_args+=("--ci") && scribe_args+=("--ci")
(( fail_on_issues )) && fallow_args+=("--fail-on-issues") && scribe_args+=("--fail-on-issues")

section_tmp="$(mktemp)"
report_tmp="$(mktemp)"
current_report="$report_tmp"
trap 'rm -f "$section_tmp" "$report_tmp"' EXIT

section_has_sarif_results() {
  python3 - "$section_tmp" <<'PYSARIF'
import json
import sys
from pathlib import Path

try:
    payload = json.loads(Path(sys.argv[1]).read_text())
except Exception:
    sys.exit(1)

for run in payload.get("runs", []):
    if run.get("results"):
        sys.exit(0)

sys.exit(1)
PYSARIF
}

append_section() {
  local title="$1"
  shift
  : > "$section_tmp"

  "$@" > "$section_tmp" 2>&1
  local section_status=$?

  # Some Fallow SARIF commands can exit non-zero even when they produced a
  # valid report with zero results. Keep the gate blocking real findings, but
  # don't fail empty SARIF output.
  if (( section_status != 0 )) && [[ "$format" == "sarif" ]] && ! section_has_sarif_results; then
    section_status=0
  fi

  if [[ -s "$section_tmp" || "$section_status" -ne 0 ]]; then
    {
      printf "\n## %s\n\n" "$title"
      cat "$section_tmp"
      printf "\n"
    } >> "$current_report"
  fi

  return "$section_status"
}

append_health_section() {
  append_section "HEALTH" bunx --bun fallow "${fallow_args[@]}" health --complexity
  local health_status=$?

  if [[ "$health_status" -ne 0 ]] && ! grep -Eq '✗|✘|×|fail|error' "$section_tmp"; then
    return 0
  fi

  return "$health_status"
}

observability_gate() {
  local gate_root="$root"

  python3 - "$gate_root" <<'PYOBS'
import json
import sys
from pathlib import Path

root = Path(sys.argv[1]).resolve()
package_path = root / "package.json"
vercel_path = root / ".vercel" / "project.json"
package = {}
deps = {}
if package_path.exists():
    try:
        package = json.loads(package_path.read_text())
    except Exception as exc:
        print(f"FAIL: package.json is unreadable: {exc}")
        sys.exit(1)
    for key in ("dependencies", "devDependencies", "optionalDependencies"):
        value = package.get(key)
        if isinstance(value, dict):
            deps.update(value)

skip_dirs = {".git", ".next", ".vercel", "node_modules", "dist", "build", "coverage", ".turbo", "DerivedData", ".expo"}
suffixes = {".ts", ".tsx", ".js", ".jsx", ".mts", ".mjs", ".cjs", ".json", ".swift", ".kt", ".java", ".m", ".mm", ".plist", ".gradle", ".kts", ".rb"}
texts = []
for path in root.rglob("*"):
    if any(part in skip_dirs for part in path.parts):
        continue
    if not path.is_file() or path.suffix not in suffixes:
        continue
    try:
        texts.append((str(path.relative_to(root)), path.read_text(errors="ignore")))
    except Exception:
        pass

blob = "\n".join(text for _, text in texts)
files = {rel for rel, _ in texts}

def has_file(name):
    return any(rel == name or rel.endswith("/" + name) for rel in files)

def has_any(*needles):
    return any(needle in blob for needle in needles)

platforms = []
if "next" in deps or has_file("next.config.ts") or has_file("next.config.js") or has_file("next.config.mjs"):
    platforms.append("next")
if "react-native" in deps or "expo" in deps or has_file("app.json") or has_file("app.config.ts") or has_file("app.config.js"):
    platforms.append("react-native")
if "electron" in deps or "electron-builder" in deps or "electron-vite" in deps:
    platforms.append("electron")
if has_file("Package.swift") or has_file("Podfile") or any(rel.endswith(".xcodeproj/project.pbxproj") for rel in files):
    platforms.append("swift")
if not platforms:
    # Unknown/non-app repo: do not block library/tooling packages.
    sys.exit(0)

failures = []

# Platform-aware package checks.
if "next" in platforms:
    if "@sentry/nextjs" not in deps:
        failures.append("Next.js: missing @sentry/nextjs dependency")
    if "posthog-js" not in deps:
        failures.append("Next.js: missing posthog-js dependency")
    if "withSentryConfig" not in blob:
        failures.append("Next.js: missing Sentry wrapper withSentryConfig in next.config.*")
    if not (has_file("instrumentation.ts") or has_file("instrumentation.js") or has_file("sentry.server.config.ts") or has_file("sentry.server.config.js")):
        failures.append("Next.js: missing server-side Sentry instrumentation")
    if not (has_file("instrumentation-client.ts") or has_file("instrumentation-client.js") or has_file("sentry.client.config.ts") or has_file("sentry.client.config.js")):
        failures.append("Next.js: missing client-side Sentry instrumentation")
    if not has_any("posthog.init"):
        failures.append("Next.js: missing PostHog browser initialization: posthog.init")
    if not has_any("PostHogProvider", "posthog-js/react"):
        failures.append("Next.js: missing PostHog React provider")

if "react-native" in platforms:
    if not any(dep in deps for dep in ("@sentry/react-native", "sentry-expo")):
        failures.append("React Native/Expo: missing @sentry/react-native or sentry-expo dependency")
    if not any(dep in deps for dep in ("posthog-react-native", "posthog-js")):
        failures.append("React Native/Expo: missing posthog-react-native dependency")
    if not has_any("Sentry.init", "SentryReactNative.init"):
        failures.append("React Native/Expo: missing Sentry.init")
    if not has_any("PostHogProvider", "new PostHog", "posthog.init"):
        failures.append("React Native/Expo: missing PostHog initialization/provider")

if "electron" in platforms:
    if not any(dep in deps for dep in ("@sentry/electron", "@sentry/node")):
        failures.append("Electron: missing @sentry/electron dependency")
    if not any(dep in deps for dep in ("posthog-js", "posthog-node")):
        failures.append("Electron: missing PostHog dependency")
    if not has_any("Sentry.init"):
        failures.append("Electron: missing Sentry.init")
    if not has_any("posthog.init", "new PostHog", "PostHog"):
        failures.append("Electron: missing PostHog initialization")

if "swift" in platforms:
    if not has_any("Sentry", "sentry-cocoa", "SentrySDK", "https://github.com/getsentry/sentry-cocoa"):
        failures.append("Swift/iOS: missing Sentry SDK dependency or import")
    if not has_any("PostHog", "posthog-ios", "https://github.com/PostHog/posthog-ios"):
        failures.append("Swift/iOS: missing PostHog SDK dependency or import")
    if not has_any("SentrySDK.start", "SentrySDK"):
        failures.append("Swift/iOS: missing SentrySDK.start")
    if not has_any("PostHogSDK.shared.setup", "PostHogConfig", "PostHogSDK"):
        failures.append("Swift/iOS: missing PostHog setup")

# Cross-platform env/key usage checks. Prefixes vary by framework, but the signal should exist in code/config.
sentry_env_signals = ("SENTRY_DSN", "NEXT_PUBLIC_SENTRY_DSN", "EXPO_PUBLIC_SENTRY_DSN", "VITE_SENTRY_DSN", "SENTRY_AUTH_TOKEN")
posthog_key_signals = ("POSTHOG_KEY", "NEXT_PUBLIC_POSTHOG_KEY", "EXPO_PUBLIC_POSTHOG_KEY", "VITE_POSTHOG_KEY")
posthog_host_signals = ("POSTHOG_HOST", "NEXT_PUBLIC_POSTHOG_HOST", "EXPO_PUBLIC_POSTHOG_HOST", "VITE_POSTHOG_HOST")
if not has_any(*sentry_env_signals):
    failures.append("missing Sentry DSN/auth env usage")
if not has_any(*posthog_key_signals):
    failures.append("missing PostHog key env usage")
if not has_any(*posthog_host_signals):
    failures.append("missing PostHog host env usage")

if failures:
    print("FAIL: observability coverage gate failed")
    print(f"Detected platforms: {', '.join(platforms)}")
    for failure in failures:
        print(f"- {failure}")
    sys.exit(1)

print(f"PASS: static Sentry/PostHog coverage checks ({', '.join(platforms)})")
PYOBS
  local static_status=$?
  (( static_status != 0 )) && return "$static_status"

  [[ ! -f "$gate_root/.vercel/project.json" ]] && return 0

  if ! command -v vercel >/dev/null 2>&1; then
    printf "FAIL: vercel CLI is required to confirm production env vars\n"
    return 1
  fi

  local env_output env_status
  if [[ -n "${VERCEL_TOKEN:-}" ]]; then
    env_output="$(cd "$gate_root" && vercel env ls production --token "$VERCEL_TOKEN" 2>&1)"
    env_status=$?
  else
    env_output="$(cd "$gate_root" && vercel env ls production 2>&1)"
    env_status=$?
  fi

  if (( env_status != 0 )); then
    printf "FAIL: unable to read Vercel production env vars\n"
    printf "%s\n" "$env_output" | sed -E 's/(vcp_)[A-Za-z0-9]+/\1***/g'
    return 1
  fi

  printf "%s\n" "$env_output" | python3 -c '
import sys
names = set()
for line in sys.stdin.read().splitlines():
    stripped = line.strip()
    if not stripped or stripped.startswith(("Vercel CLI", "Retrieving", ">", "name ")):
        continue
    first = stripped.split()[0]
    if first.isidentifier() or first.startswith(("NEXT_PUBLIC_", "EXPO_PUBLIC_", "VITE_")):
        names.add(first)
required = [
    ("Sentry DSN", ("NEXT_PUBLIC_SENTRY_DSN", "SENTRY_DSN", "EXPO_PUBLIC_SENTRY_DSN", "VITE_SENTRY_DSN")),
    ("SENTRY_AUTH_TOKEN", ("SENTRY_AUTH_TOKEN",)),
    ("SENTRY_ORG", ("SENTRY_ORG",)),
    ("SENTRY_PROJECT", ("SENTRY_PROJECT",)),
    ("PostHog key", ("NEXT_PUBLIC_POSTHOG_KEY", "POSTHOG_KEY", "EXPO_PUBLIC_POSTHOG_KEY", "VITE_POSTHOG_KEY")),
    ("PostHog host", ("NEXT_PUBLIC_POSTHOG_HOST", "POSTHOG_HOST", "EXPO_PUBLIC_POSTHOG_HOST", "VITE_POSTHOG_HOST")),
]
missing = [label for label, options in required if not any(option in names for option in options)]
if missing:
    print("FAIL: Vercel production env vars missing")
    for item in missing:
        print(f"- {item}")
    sys.exit(1)
print("PASS: Vercel production env vars confirmed for Sentry/PostHog")
'
}

prefer_push_only_fallow_gate() {
  local gate_path="$root/.claude/hooks/fallow-gate.sh"

  if [[ ! -f "$gate_path" ]]; then
    return 0
  fi

  python3 - "$gate_path" <<'PYGATE'
import sys
from pathlib import Path

path = Path(sys.argv[1])
content = path.read_text()
content = content.replace(
    "Blocks Claude Code git commit and git push when fallow audit returns verdict fail.",
    "Blocks Claude Code git push when fallow audit returns verdict fail.",
)
content = content.replace(
    "git[[:space:]]+(commit|push)([[:space:]]|$)",
    "git[[:space:]]+push([[:space:]]|$)",
)
path.write_text(content)
PYGATE
}

overall_status=0

(
  cd "$root" || exit 1
  bunx --bun fallow init --quiet > /dev/null 2>&1
  bunx --bun fallow setup-hooks --quiet > /dev/null 2>&1
)

prefer_push_only_fallow_gate

printf "# FALLOW REVIEW\n" > "$report_tmp"

append_section "OBSERVABILITY" observability_gate || overall_status=1
append_health_section || overall_status=1
append_section "AUDIT" bunx --bun fallow "${fallow_args[@]}" audit || overall_status=1
append_section "DEAD" bunx --bun fallow "${fallow_args[@]}" dead-code || overall_status=1
append_section "DUPLICATION" bunx --bun fallow "${fallow_args[@]}" dupes || overall_status=1
append_section "DOCSTRINGS" "$scribe_bin" "${scribe_args[@]}" || overall_status=1

cp "$report_tmp" "$review_file"

if (( overall_status != 0 )); then
  if [[ "$format" == "human" ]]; then
    cat "$report_tmp"
  else
    human_tmp="$(mktemp)"
    trap 'rm -f "$section_tmp" "$report_tmp" "$human_tmp"' EXIT
    current_report="$human_tmp"
    printf "# FALLOW REVIEW\n" > "$human_tmp"
    human_fallow_args=("--root" "$root" "--format" "human")
    human_scribe_args=("--root" "$root" "--format" "human")
    (( explain )) && human_fallow_args+=("--explain") && human_scribe_args+=("--explain")
    (( summary )) && human_fallow_args+=("--summary") && human_scribe_args+=("--summary")

    append_section "OBSERVABILITY" observability_gate
    append_section "HEALTH" bunx --bun fallow "${human_fallow_args[@]}" health --complexity
    append_section "AUDIT" bunx --bun fallow "${human_fallow_args[@]}" audit
    append_section "DEAD" bunx --bun fallow "${human_fallow_args[@]}" dead-code
    append_section "DUPLICATION" bunx --bun fallow "${human_fallow_args[@]}" dupes
    append_section "DOCSTRINGS" "$scribe_bin" "${human_scribe_args[@]}"
    cat "$human_tmp"
  fi
fi

exit "$overall_status"
